{
  "name": "epixodo-lite",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "node scripts/next-dev-e2e.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "start-server-and-test dev:e2e http://localhost:3137 test:e2e:run",
    "test:e2e:run": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install",
    "openspec": "openspec",
    "openspec:validate": "openspec validate --all --strict --no-interactive"
  },
  "dependencies": {
    "next": "16.2.6",
    "pocketbase": "^0.26.8",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "start-server-and-test": "^3.0.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
